{
  "name": "aquasense-backend",
  "version": "1.0.0",
  "description": "AquaSense/CrayFarm API and static file server",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "cleanup:history:dry": "node scripts/cleanup-rtdb-history.js --dry-run",
    "cleanup:history": "node scripts/cleanup-rtdb-history.js",
    "cleanup:presets": "node scripts/cleanup-duplicate-presets.js",
    "update:crayfish": "node scripts/update-crayfish-preset.js"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "firebase-admin": "^13.8.0"
  }
}
